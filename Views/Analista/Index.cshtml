@model List<ParcialExamen.Models.SolicitudCredito>

@{
    ViewData["Title"] = "Panel Analista";
}

<div class="container mt-4">
    <h1 class="mb-4">Panel Analista</h1>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success" role="alert">@successMessage</div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="alert alert-danger" role="alert">@errorMessage</div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info" role="alert">
            No hay solicitudes pendientes.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Cliente</th>
                        <th>Fecha</th>
                        <th>Monto</th>
                        <th>Ingresos</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var solicitud in Model)
                    {
                        <tr>
                            <td>@solicitud.Id</td>
                            <td>@(solicitud.Cliente?.Nombre ?? "N/A")</td>
                            <td>@solicitud.FechaSolicitud.ToString("dd/MM/yyyy")</td>
                            <td>@solicitud.MontoSolicitado.ToString("C2")</td>
                            <td>@(solicitud.Cliente?.IngresosMensuales.ToString("C2") ?? "N/A")</td>
                            <td>
                                <div class="d-flex justify-content-end gap-2 flex-wrap">
                                    <form asp-controller="Analista" asp-action="Aprobar" asp-route-id="@solicitud.Id" method="post">
                                        <button type="submit" class="btn btn-sm btn-success">Aprobar</button>
                                    </form>

                                    <form asp-controller="Analista" asp-action="Rechazar" asp-route-id="@solicitud.Id" method="post" class="d-flex gap-2">
                                        <input name="motivoRechazo" class="form-control form-control-sm" placeholder="Motivo" required />
                                        <button type="submit" class="btn btn-sm btn-danger">Rechazar</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
