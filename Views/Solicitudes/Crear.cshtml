@model ParcialExamen.Models.RegistroSolicitudViewModel

@{
    ViewData["Title"] = "Nueva solicitud";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">Nueva solicitud</h1>
        <a asp-controller="Solicitudes" asp-action="Index" class="btn btn-outline-secondary">Volver</a>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success" role="alert">
            @successMessage
        </div>
    }

    <form asp-controller="Solicitudes" asp-action="Crear" method="post" class="card">
        <div class="card-body">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="MontoSolicitado" class="form-label"></label>
                <input asp-for="MontoSolicitado" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="MontoSolicitado" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary">Registrar solicitud</button>
        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
