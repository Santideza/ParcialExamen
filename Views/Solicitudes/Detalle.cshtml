@model ParcialExamen.Models.SolicitudCredito

@{
    ViewData["Title"] = "Detalle de solicitud";
    var badgeClass = Model.Estado switch
    {
        ParcialExamen.Models.EstadoSolicitud.Aprobado => "bg-success",
        ParcialExamen.Models.EstadoSolicitud.Rechazado => "bg-danger",
        _ => "bg-warning text-dark"
    };
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">Solicitud #@Model.Id</h1>
        <span class="badge @badgeClass fs-6">@Model.Estado</span>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="row g-4">
                <div class="col-md-6">
                    <h2 class="h5 text-muted">Informacion de solicitud</h2>
                    <dl class="row mb-0">
                        <dt class="col-sm-5">Fecha solicitud</dt>
                        <dd class="col-sm-7">@Model.FechaSolicitud.ToString("dd/MM/yyyy HH:mm")</dd>

                        <dt class="col-sm-5">Monto solicitado</dt>
                        <dd class="col-sm-7">@Model.MontoSolicitado.ToString("C2")</dd>

                        <dt class="col-sm-5">Estado</dt>
                        <dd class="col-sm-7"><span class="badge @badgeClass">@Model.Estado</span></dd>

                        @if (!string.IsNullOrWhiteSpace(Model.MotivoRechazo))
                        {
                            <dt class="col-sm-5">Motivo rechazo</dt>
                            <dd class="col-sm-7">@Model.MotivoRechazo</dd>
                        }
                    </dl>
                </div>

                <div class="col-md-6">
                    <h2 class="h5 text-muted">Informacion de cliente</h2>
                    <dl class="row mb-0">
                        <dt class="col-sm-5">Cliente</dt>
                        <dd class="col-sm-7">#@Model.ClienteId</dd>

                        <dt class="col-sm-5">Ingresos mensuales</dt>
                        <dd class="col-sm-7">@(Model.Cliente?.IngresosMensuales.ToString("C2") ?? "N/A")</dd>

                        <dt class="col-sm-5">Estado cliente</dt>
                        <dd class="col-sm-7">
                            @if (Model.Cliente?.Activo == true)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactivo</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a asp-controller="Solicitudes" asp-action="Index" class="btn btn-secondary">Volver</a>
    </div>
</div>
