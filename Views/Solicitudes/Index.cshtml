@model ParcialExamen.Models.FiltroSolicitudViewModel

@{
    ViewData["Title"] = "Mis solicitudes";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">Mis solicitudes</h1>
        <a asp-controller="Solicitudes" asp-action="Crear" class="btn btn-primary">Nueva solicitud</a>
    </div>

    <form method="get" asp-controller="Solicitudes" asp-action="Index" class="card mb-4">
        <div class="card-header fw-semibold">Filtros</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label asp-for="Estado" class="form-label"></label>
                    <select asp-for="Estado" class="form-select"
                            asp-items="Html.GetEnumSelectList<ParcialExamen.Models.EstadoSolicitud>()">
                        <option value="">Todos</option>
                    </select>
                    <span asp-validation-for="Estado" class="text-danger small"></span>
                </div>

                <div class="col-md-2">
                    <label asp-for="MontoMin" class="form-label"></label>
                    <input asp-for="MontoMin" type="number" min="0" step="0.01" class="form-control" />
                    <span asp-validation-for="MontoMin" class="text-danger small"></span>
                </div>

                <div class="col-md-2">
                    <label asp-for="MontoMax" class="form-label"></label>
                    <input asp-for="MontoMax" type="number" min="0" step="0.01" class="form-control" />
                    <span asp-validation-for="MontoMax" class="text-danger small"></span>
                </div>

                <div class="col-md-2">
                    <label asp-for="FechaInicio" class="form-label"></label>
                    <input asp-for="FechaInicio" type="date" class="form-control" />
                    <span asp-validation-for="FechaInicio" class="text-danger small"></span>
                </div>

                <div class="col-md-2">
                    <label asp-for="FechaFin" class="form-label"></label>
                    <input asp-for="FechaFin" type="date" class="form-control" />
                    <span asp-validation-for="FechaFin" class="text-danger small"></span>
                </div>

                <div class="col-md-1 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Filtrar</button>
                </div>
            </div>

            <div asp-validation-summary="ModelOnly" class="text-danger mt-3"></div>
        </div>
    </form>

    @if (!Model.Resultados.Any())
    {
        <div class="alert alert-info" role="alert">
            No hay solicitudes que coincidan con los filtros.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Fecha</th>
                        <th>Monto solicitado</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var solicitud in Model.Resultados)
                    {
                        var badgeClass = solicitud.Estado switch
                        {
                            ParcialExamen.Models.EstadoSolicitud.Aprobado => "bg-success",
                            ParcialExamen.Models.EstadoSolicitud.Rechazado => "bg-danger",
                            _ => "bg-warning text-dark"
                        };

                        <tr>
                            <td>@solicitud.Id</td>
                            <td>@solicitud.FechaSolicitud.ToString("dd/MM/yyyy")</td>
                            <td>@solicitud.MontoSolicitado.ToString("C2")</td>
                            <td><span class="badge @badgeClass">@solicitud.Estado</span></td>
                            <td class="text-end">
                                <a asp-controller="Solicitudes"
                                   asp-action="Detalle"
                                   asp-route-id="@solicitud.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    Ver detalle
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
